# Copy this file to .env for local development. Do not commit real secrets.

# Tenant/source config path. Copy config/tenants.example.yaml to the ignored
# config/tenants.local.yaml when you need local tenant/source overrides.
KABUTO_TENANTS_CONFIG=config/tenants.example.yaml

# GitHub token used by future ingestion tickets. Tenant YAML stores only this
# environment-variable name, never the token value itself.
GITHUB_TOKEN=
# GH_TOKEN=

# Optional local data root. Defaults to .local/data when unset.
KABUTO_DATA_ROOT=.local/data

# Optional Dagster home. Defaults can be supplied by your shell when running Dagster.
DAGSTER_HOME=.local/dagster
