# Copy this file to .env for local development. Do not commit real secrets.

# GitHub token used by future ingestion tickets.
# Either GITHUB_TOKEN or GH_TOKEN may be used by validation/ingestion code.
GITHUB_TOKEN=
# GH_TOKEN=

# Optional local data root. Defaults to .local/data when unset.
KABUTO_DATA_ROOT=.local/data

# Optional Dagster home. Defaults can be supplied by your shell when running Dagster.
DAGSTER_HOME=.local/dagster
