# Copy this file to .env for local development. Do not commit real secrets.

# Tenant/source config path. Copy config/tenants.example.yaml to the ignored
# config/tenants.local.yaml when you need local tenant/source overrides.
KABUTO_TENANTS_CONFIG=config/tenants.example.yaml

# GitHub auth. Tenant YAML stores only env-var names, never token values.
# Use a read-only fine-grained PAT exported from Proton Pass or another secret store.
GITHUB_TOKEN=
# GH_TOKEN=

# GitHub incremental PR sync. Enabled by default; after cursor state exists, later
# runs use persisted updated_at cursors with a small lookback safety window.
KABUTO_GITHUB_INCREMENTAL_ENABLED=true
KABUTO_GITHUB_INCREMENTAL_LOOKBACK_DAYS=1
# Optional first-run bound for portfolio-scale demos; unset means full first scan.
# KABUTO_GITHUB_INITIAL_LOOKBACK_DAYS=180

# Storage profile. Keep local as the default for tests and everyday development.
# Supported values: local, minio, r2.
KABUTO_STORAGE_PROFILE=local

# Optional local data root for the local storage profile. Defaults to .local/data when unset.
KABUTO_DATA_ROOT=.local/data

# Optional object-store prefix used by MinIO/R2 profiles. Do not include leading/trailing slashes.
KABUTO_STORAGE_PREFIX=kabuto-kurage

# MinIO profile placeholders. Store real values in Proton Pass or another secret manager,
# export them into your shell when needed, and do not commit them.
# KABUTO_STORAGE_PROFILE=minio
# KABUTO_MINIO_BUCKET=kabuto-dev
# KABUTO_MINIO_ENDPOINT_URL=http://localhost:9000
# KABUTO_MINIO_REGION=us-east-1
# KABUTO_MINIO_ALLOW_HTTP=true
# KABUTO_MINIO_ACCESS_KEY_ID=
# KABUTO_MINIO_SECRET_ACCESS_KEY=

# Cloudflare R2 profile placeholders. Store real values in Proton Pass or another
# secret manager, export them into your shell when needed, and do not commit them.
# KABUTO_STORAGE_PROFILE=r2
# KABUTO_R2_BUCKET=kabuto-r2-bucket-name
# KABUTO_R2_ACCOUNT_ID=
# KABUTO_R2_REGION=auto
# KABUTO_R2_ACCESS_KEY_ID=
# KABUTO_R2_SECRET_ACCESS_KEY=

# Optional Dagster home. Defaults can be supplied by your shell when running Dagster.
DAGSTER_HOME=.local/dagster
